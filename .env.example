# =============================================================================
# WaterPulse Docker — Environment Variables Template
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Replace placeholder values with real secrets
#   3. Run:  docker-compose up --build
#
# SECURITY:
#   - .env is listed in .gitignore and will NEVER be committed
#   - Only this .example template (with placeholder values) is committed
#   - Docker Compose automatically loads .env from the project root
#
# NOTE: DATABASE_URL and DATABASE_URL_SYNC are NOT set here.
#   They are constructed in docker-compose.yml using POSTGRES_PASSWORD from
#   this file and the Docker service name "db" as the hostname. This ensures
#   the backend connects to the containerised PostgreSQL, not a local install.
#   If you set DATABASE_URL here, it will be overridden by docker-compose.yml.
# =============================================================================

# -----------------------------------------------------------------------------
# Database credentials
# -----------------------------------------------------------------------------
# Used by both the PostgreSQL container (to create the database) and the
# backend container (to connect to it). Choose a strong password.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# SECRET_KEY: Used to sign JWT tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ALGORITHM: JWT signing algorithm (HS256 is the default and recommended)
# ACCESS_TOKEN_EXPIRE_MINUTES: How long a login session lasts (1440 = 24 hours)
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Data Sources
# -----------------------------------------------------------------------------
# These are public APIs — no API keys needed. The default values work out of
# the box. Override only if an API changes its base URL.
#
# ECCC: Environment and Climate Change Canada — primary national data source
# Alberta: Provincial supplementary data (rivers.alberta.ca)
# Open-Meteo: Weather and air quality (free tier, no key required)
ECCC_BASE_URL=https://api.weather.gc.ca
ECCC_DATAMART_BASE_URL=https://dd.weather.gc.ca/today/hydrometric
ALBERTA_BASE_URL=https://rivers.alberta.ca
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_AQI_URL=https://air-quality-api.open-meteo.com/v1/air-quality

# -----------------------------------------------------------------------------
# Scheduler
# -----------------------------------------------------------------------------
# How often the background scheduler refreshes readings (in minutes).
# Lower values = more frequent API calls to data sources.
READINGS_REFRESH_INTERVAL_MINUTES=10

# -----------------------------------------------------------------------------
# Reverse proxy (Caddy)
# -----------------------------------------------------------------------------
# SITE_ADDRESS controls dev vs prod TLS behaviour:
#   Dev:  :80             — plain HTTP on localhost, no TLS
#   Prod: waterpulse.ca   — Caddy auto-provisions TLS via Let's Encrypt
SITE_ADDRESS=:80

# Let's Encrypt account email (for cert expiry notices). Required for prod;
# ignored when SITE_ADDRESS=:80. Use a monitored inbox.
ACME_EMAIL=

# -----------------------------------------------------------------------------
# Cookie security
# -----------------------------------------------------------------------------
# Sets the Secure flag on auth cookies. False for local HTTP dev; True on
# HTTPS in production. If True on HTTP, browsers silently drop the cookie
# and login appears to fail.
COOKIE_SECURE=False
