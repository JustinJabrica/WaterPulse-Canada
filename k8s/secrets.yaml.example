# =============================================================================
# Kubernetes Secret — WaterPulse (EXAMPLE — copy to secrets.yaml)
# =============================================================================
#
# Secrets store sensitive values (passwords, API keys) that should never be
# committed to version control. Kubernetes stores them base64-encoded in the
# cluster's etcd database.
#
# Setup:
#   1. Copy this file to secrets.yaml:
#        cp k8s/secrets.yaml.example k8s/secrets.yaml
#
#   2. Generate base64 values for your secrets:
#
#      PowerShell (Windows):
#        [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("your-strong-password"))
#        [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("your-random-secret-key"))
#
#      Bash (Linux/Mac/Git Bash):
#        echo -n "your-strong-password" | base64
#        echo -n "your-random-secret-key" | base64
#
#   3. Replace the placeholder values below with the base64 output
#
#   4. Apply to the cluster:
#        kubectl apply -f k8s/secrets.yaml
#
# IMPORTANT:
#   - secrets.yaml is gitignored — NEVER commit actual secret values
#   - base64 is NOT encryption — it's just encoding. In production, use a
#     cloud secret manager (AWS Secrets Manager, GCP Secret Manager, etc.)
#   - Do NOT use "echo -n" in PowerShell — it does not suppress newlines
#     like Bash does. The hidden newline gets encoded into the password and
#     silently breaks database authentication. Use the [Convert] method above.
#
# How it's used:
#   Deployments reference these secrets via secretKeyRef. For example, the
#   backend deployment reads POSTGRES_PASSWORD from this Secret and injects
#   it as an environment variable inside the container.
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: waterpulse-secrets
  namespace: waterpulse
# Opaque is the default Secret type — it holds arbitrary key-value pairs.
# Other types exist for TLS certificates, Docker registry credentials, etc.
type: Opaque
data:
  # Replace these with your own base64-encoded values.
  # PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("my-password"))
  # Bash:       echo -n "my-password" | base64
  # Both produce: bXktcGFzc3dvcmQ=
  POSTGRES_PASSWORD: Y2hhbmdlLW1l
  SECRET_KEY: Y2hhbmdlLW1l
