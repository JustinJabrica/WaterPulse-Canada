# =============================================================================
# WaterPulse Frontend — Dockerfile (Multi-Stage Build)
# =============================================================================
#
# Builds the Next.js frontend as a standalone production server.
#
# Three stages keep the final image small (~100 MB vs ~500 MB with full
# node_modules):
#   1. deps    — Install npm dependencies (cached unless package*.json changes)
#   2. builder — Copy source code and run "npm run build"
#   3. runner  — Copy only the standalone output (server.js + static assets)
#
# IMPORTANT: NEXT_PUBLIC_* build args
#   Next.js bakes any variable prefixed with NEXT_PUBLIC_ into the client-side
#   JavaScript bundle at BUILD time. This means:
#   - The value CANNOT be changed at runtime — you must rebuild the image
#   - For development: use http://localhost:8000 (direct backend access)
#   - For production behind Caddy: use the full public domain (e.g. https://waterpulse.ca)
#   - This is a Next.js constraint, not a Docker limitation
#
#   The same rule applies to NEXT_PUBLIC_TILES_URL (self-hosted PMTiles
#   basemap URL). Leave blank to fall back to CartoDB Voyager on /map.
#
# The standalone output mode is enabled in next.config.mjs (output: "standalone").
# It produces a self-contained server.js that includes only the node_modules
# packages actually needed at runtime, dramatically reducing image size.
#
# Build:   docker build --build-arg NEXT_PUBLIC_API_URL=http://localhost:8000 \
#            -t waterpulse-frontend ./waterpulse-frontend
# Run:     docker run -p 3000:3000 waterpulse-frontend
# =============================================================================

# ── Stage 1: Install dependencies ────────────────────────────────────────────
# Separate stage so the npm install layer is cached. Only changes to
# package.json or package-lock.json invalidate this layer.
# "npm ci" (clean install) is used instead of "npm install" because it:
#   - Installs exact versions from package-lock.json (reproducible builds)
#   - Is faster in CI/Docker (skips the dependency resolution step)
#   - Fails if package-lock.json is out of sync with package.json
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

# ── Stage 2: Build the Next.js application ──────────────────────────────────
# Copies node_modules from the deps stage, then copies all source files and
# runs the production build. The build output goes to .next/standalone/.
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build argument for the backend API URL — baked into client JS at build time.
# Override with: docker build --build-arg NEXT_PUBLIC_API_URL=https://your-domain.com
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Self-hosted PMTiles basemap URL (optional). When unset, the map falls back
# to CartoDB Voyager. See tiles/README.md at the repo root.
ARG NEXT_PUBLIC_TILES_URL=
ENV NEXT_PUBLIC_TILES_URL=$NEXT_PUBLIC_TILES_URL

RUN npm run build

# ── Stage 3: Production runner ───────────────────────────────────────────────
# Minimal image containing only what's needed to run the server:
#   - .next/standalone/  — self-contained Node.js server (server.js + minimal deps)
#   - .next/static/      — pre-built CSS, JS, and other static assets
#   - public/            — favicon, SVGs, and other public files
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production

# Copy the standalone server output from the builder stage.
# The standalone directory contains server.js and a pruned node_modules.
COPY --from=builder /app/.next/standalone ./
# Static assets are not included in standalone and must be copied separately.
COPY --from=builder /app/.next/static ./.next/static
# Public directory contains static files served at the root (favicon, etc.).
COPY --from=builder /app/public ./public

EXPOSE 3000

# Start the standalone Next.js server.
# server.js is generated by Next.js when output: "standalone" is configured.
CMD ["node", "server.js"]
