# =============================================================================
# WaterPulse Frontend — Docker Ignore
# =============================================================================
# Files and directories excluded from the Docker build context.
#
# Excluding node_modules/ is critical — without this, Docker would copy the
# entire directory (~300 MB) into the build context, only to be overwritten
# by "npm ci" inside the container. This makes builds slow and wastes space.
#
# The .next/ directory is also excluded because it contains the local build
# output from the host machine. The Dockerfile creates a fresh production
# build inside the container.
# =============================================================================

# ── Dependencies (reinstalled inside the container) ──
node_modules/

# ── Local build output (rebuilt inside the container) ─
.next/
out/

# ── Environment files with secrets ────────────────────
.env
.env.*
.env.local

# ── Version control ──────────────────────────────────
.git/
.gitignore

# ── Documentation (not needed at runtime) ─────────────
README.md
CLAUDE.md
AGENTS.md
