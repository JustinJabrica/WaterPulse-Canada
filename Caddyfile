# =============================================================================
# WaterPulse Canada — Caddy v2 Reverse Proxy Configuration
# =============================================================================
#
# Routes all browser traffic through a single origin, enabling HTTPOnly cookie
# auth between the Next.js frontend and FastAPI backend (same-origin requirement).
#
# Routing rules:
#   /api/*        → backend:8000   FastAPI REST endpoints
#   /docs         → backend:8000   Swagger UI
#   /docs/*       → backend:8000   Swagger sub-resources
#   /openapi.json → backend:8000   OpenAPI spec
#   /*            → frontend:3000  Next.js pages and static assets
#
# SITE_ADDRESS controls dev vs prod TLS behaviour:
#   Dev  (.env):  SITE_ADDRESS=:80              — plain HTTP, no TLS attempted
#   Prod (.env):  SITE_ADDRESS=waterpulse.ca    — automatic Let's Encrypt via ACME
#
# ACME_EMAIL is used by Let's Encrypt for cert expiry notices (prod only;
# ignored when SITE_ADDRESS=:80).
#
# The 30-minute read/write timeout on the backend matches the k8s ingress
# config so long-running admin sync endpoints don't hit a 504.
# =============================================================================

{
    email {$ACME_EMAIL}
}

{$SITE_ADDRESS} {
    encode zstd gzip

    @backend path /api/* /docs /docs/* /openapi.json
    reverse_proxy @backend backend:8000 {
        transport http {
            dial_timeout 30s
            read_timeout 30m
            write_timeout 30m
        }
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        # X-Forwarded-For and X-Forwarded-Proto are set automatically by Caddy's
        # reverse_proxy. Re-enable explicitly if a future upstream needs a
        # non-default value.
        # header_up X-Forwarded-For {remote_host}
        # header_up X-Forwarded-Proto {scheme}
    }

    reverse_proxy frontend:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        # header_up X-Forwarded-For {remote_host}
        # header_up X-Forwarded-Proto {scheme}
    }
}
